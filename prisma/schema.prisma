generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Int
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Category {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
}
model Brand {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  createdAt DateTime @default(now())
}
